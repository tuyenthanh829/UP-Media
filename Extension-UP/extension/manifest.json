{
  "manifest_version": 3,
  "name": "NotebookLM Sheet Exporter",
  "description": "Scrape NotebookLM quiz questions and export them to CSV or TSV.",
  "version": "1.0.0",
  "action": {
    "default_title": "NotebookLM Sheet Exporter",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background/background.js"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://notebooklm.google.com/*",
    "https://*.usercontent.goog/*",
    "https://usercontent.goog/*",
    "https://*.googleusercontent.com/*",
    "https://googleusercontent.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://notebooklm.google.com/*",
        "https://*.usercontent.goog/*",
        "https://usercontent.goog/*",
        "https://*.googleusercontent.com/*",
        "https://googleusercontent.com/*"
      ],
      "js": [
        "src/content/content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
