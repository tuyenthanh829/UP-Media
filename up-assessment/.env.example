# =============================================================
# UP Assessment Platform — Environment Variables
# Copy file này thành .env.local và điền giá trị thật
#   cp .env.example .env.local
# KHÔNG commit .env.local
# =============================================================

# --- Supabase (bắt buộc) ---
# Lấy tại: Supabase Dashboard → Settings → API

# Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon/public key — an toàn để expose ra browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — CHỈ dùng server-side (invite flow)
# KHÔNG bao giờ đặt vào NEXT_PUBLIC_ hay gửi về browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- App URL (bắt buộc) ---
# URL của app khi deploy; dùng cho link activation email
# Local: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Notion Integration (cần cho Notion sync) ---
# Lấy tại: notion.so/my-integrations → Integration token
NOTION_INTEGRATION_TOKEN=secret_your-notion-integration-token

# ID của Notion database "Question Bank"
# Lấy từ URL của database page: notion.so/<workspace>/<DATABASE_ID>?v=...
NOTION_QUESTION_BANK_DATABASE_ID=your-notion-database-id

# Secret dùng để xác thực webhook từ Notion automation (tùy chọn nhưng khuyến nghị)
# Đặt chuỗi ngẫu nhiên bất kỳ, sau đó append vào URL webhook: ?secret=<giá_trị_này>
NOTION_WEBHOOK_SECRET=your-random-webhook-secret
